# Glasgow Executive Chauffeurs Environment Variables
# Copy this file to .env and fill in real values

# Resend API Key (get from https://resend.com/api-keys)
# Free tier: 100 emails per day
# Runtime secret — also set via `wrangler secret put RESEND_API_KEY`
RESEND_API_KEY=your_resend_api_key_here

# Email address where booking requests will be sent
# Runtime var — also set in Cloudflare Workers dashboard
TO_EMAIL=bookings@gec.limo

# MapTiler API Key — powers the 3D Glasgow city map in the hero
# Get a free key at https://cloud.maptiler.com/account/keys/
# Free tier: 100,000 tile requests/month
# Build-time var (NEXT_PUBLIC_*) — inlined into the browser bundle at build,
# so it must be present locally when you run `opennextjs-cloudflare build`.
# Setting it in the Cloudflare dashboard does NOT work for NEXT_PUBLIC_* vars.
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key_here
